<!-- Beginning of Page Layout -->

<div class="page-wrap">
  <div class="page-inner">

    <!-- Header -->
    <div class="header-row fu">
      <a href="/home" class="back-btn">&#8592;</a>

      <div class="session-avatar" id="sessionAvatar">📚</div>

      <div class="session-label-wrap">
        <div class="live-badge">
          <div class="live-dot"></div>
          Live Session
        </div>
        <h1 class="session-title" id="sessionTitle">Studying</h1>
      </div>

      <a href="/playlists" class="end-btn" id="endBtn" onclick="handleEndSession()">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
        End Session
      </a>
    </div>

    <!-- Stats row -->
    <div class="stats-grid fu d1">
      <div class="stat-card">
        <svg class="icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        <div class="stat-value" id="statTracks">1</div>
        <div class="stat-label">Tracks</div>
      </div>
      <div class="stat-card">
        <svg class="icon-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div class="stat-value" id="statDuration">0m 0s</div>
        <div class="stat-label">Duration</div>
      </div>
      <div class="stat-card">
        <svg class="icon-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        <div class="stat-value" id="statEnergy">—</div>
        <div class="stat-label">Energy</div>
      </div>
      <div class="stat-card">
        <svg class="icon-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        <div class="stat-value" id="statVibe">—</div>
        <div class="stat-label">Vibe</div>
      </div>
    </div>

    <!-- Now playing -->
    <div class="fu d2">
      <h2 class="section-heading">Now Playing</h2>
      <div class="now-playing-card" id="nowPlayingCard">
        <!-- Empty state shown until first track loads -->
        <div class="now-playing-empty" id="npEmpty">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
          <p>No track playing</p>
        </div>
        <!-- Populated by JS once a track loads -->
        <div id="npContent" style="display:none;">
          <div class="np-row">
            <div class="art-wrap">
              <img class="album-art" id="npArt" src="" alt="Album art"/>
              <div class="art-pulse">
                <div class="art-dot"></div>
              </div>
            </div>
            <div class="np-info">
              <p class="np-title"  id="npTitle">—</p>
              <p class="np-artist" id="npArtist">—</p>
              <p class="np-album"  id="npAlbum">—</p>
            </div>
          </div>
          <div class="features-row">
            <div>
              <div class="feature-label">Energy</div>
              <div class="feature-bar"><div class="feature-fill" id="fEnergy" style="width:0%"></div></div>
              <div class="feature-val" id="vEnergy">—</div>
            </div>
            <div>
              <div class="feature-label">Dance</div>
              <div class="feature-bar"><div class="feature-fill" id="fDance" style="width:0%"></div></div>
              <div class="feature-val" id="vDance">—</div>
            </div>
            <div>
              <div class="feature-label">Mood</div>
              <div class="feature-bar"><div class="feature-fill" id="fMood" style="width:0%"></div></div>
              <div class="feature-val" id="vMood">—</div>
            </div>
            <div>
              <div class="feature-label">Tempo</div>
              <div class="feature-bar" style="background:transparent;"></div>
              <div class="feature-val" id="vTempo">—</div>
            </div>
            <div>
              <div class="feature-label">Acoustic</div>
              <div class="feature-bar"><div class="feature-fill" id="fAcoustic" style="width:0%"></div></div>
              <div class="feature-val" id="vAcoustic">—</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Session history -->
    <div class="fu d3">
      <h2 class="section-heading">Session History</h2>
      <div class="track-list" id="trackList"></div>
    </div>

  </div>
</div>

<!-- Beginning of Script Code and Functions -->

<script>
  // ── Load session info from home page selection ──
  const sessionLabel = sessionStorage.getItem('selectedLabel') || 'Studying';
  const sessionEmoji = sessionStorage.getItem('selectedEmoji') || '📚';
  document.getElementById('sessionTitle').textContent  = sessionLabel;
  document.getElementById('sessionAvatar').textContent = sessionEmoji;

  // ── Mock track data ──
  // Replaced later with real Spotify API "currently playing" polling
  const mockTracks = [
    {
      id: '1',
      name: 'Blinding Lights',
      artist: 'The Weeknd',
      album: 'After Hours',
      duration: 200,
      imageUrl: 'https://images.unsplash.com/photo-1470225620780-dba8ba36b745?w=400',
      energy: 0.73, dance: 0.51, mood: 0.33, tempo: 171, acoustic: 0.001,
    },
    {
      id: '2',
      name: 'Levitating',
      artist: 'Dua Lipa',
      album: 'Future Nostalgia',
      duration: 203,
      imageUrl: 'https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?w=400',
      energy: 0.82, dance: 0.70, mood: 0.87, tempo: 103, acoustic: 0.07,
    },
    {
      id: '3',
      name: 'Watermelon Sugar',
      artist: 'Harry Styles',
      album: 'Fine Line',
      duration: 174,
      imageUrl: 'https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=400',
      energy: 0.73, dance: 0.55, mood: 0.56, tempo: 95, acoustic: 0.12,
    },
    {
      id: '4',
      name: 'Sunflower',
      artist: 'Post Malone, Swae Lee',
      album: 'Spider-Man: Into the Spider-Verse',
      duration: 158,
      imageUrl: 'https://images.unsplash.com/photo-1487180144351-b8472da7d491?w=400',
      energy: 0.48, dance: 0.76, mood: 0.91, tempo: 90, acoustic: 0.56,
    },
    {
      id: '5',
      name: 'Stay',
      artist: 'The Kid LAROI, Justin Bieber',
      album: 'F*CK LOVE 3',
      duration: 141,
      imageUrl: 'https://images.unsplash.com/photo-1514525253161-7a46d19cd819?w=400',
      energy: 0.61, dance: 0.59, mood: 0.48, tempo: 169, acoustic: 0.04,
    },
    {
      id: '6',
      name: 'Good 4 U',
      artist: 'Olivia Rodrigo',
      album: 'SOUR',
      duration: 178,
      imageUrl: 'https://images.unsplash.com/photo-1506157786151-b8491531f063?w=400',
      energy: 0.84, dance: 0.56, mood: 0.67, tempo: 164, acoustic: 0.03,
    },
  ];

  // ── State ──
  let playedTracks  = [];   // tracks heard so far this session
  let elapsedSeconds = 0;   // running session timer
  let trackIndex    = 0;    // current position in mock array

  // ── Format helpers ──
  function pct(val) { return Math.round(val * 100) + '%'; }
  function fmtDuration(secs) {
    const mins = Math.floor(secs / 60);
    const s    = secs % 60;
    return mins + 'm ' + s + 's';
  }
  function fmtTrackTime(secs) {
    const m = Math.floor(secs / 60);
    const s = String(secs % 60).padStart(2, '0');
    return m + ':' + s;
  }

  // ── Update the Now Playing card ──
  function updateNowPlaying(track) {
    // Hide empty state, show content
    document.getElementById('npEmpty').style.display   = 'none';
    document.getElementById('npContent').style.display = 'block';

    document.getElementById('npArt').src        = track.imageUrl;
    document.getElementById('npArt').alt        = track.album;
    document.getElementById('npTitle').textContent  = track.name;
    document.getElementById('npArtist').textContent = track.artist;
    document.getElementById('npAlbum').textContent  = track.album;

    document.getElementById('fEnergy').style.width   = pct(track.energy);
    document.getElementById('fDance').style.width    = pct(track.dance);
    document.getElementById('fMood').style.width     = pct(track.mood);
    document.getElementById('fAcoustic').style.width = pct(track.acoustic);

    document.getElementById('vEnergy').textContent   = pct(track.energy);
    document.getElementById('vDance').textContent    = pct(track.dance);
    document.getElementById('vMood').textContent     = pct(track.mood);
    document.getElementById('vTempo').textContent    = Math.round(track.tempo) + ' bpm';
    document.getElementById('vAcoustic').textContent = pct(track.acoustic);
  }

  // ── Update the 4 session stat cards ──
  function updateStats() {
    const avgEnergy = playedTracks.reduce(function(sum, t) { return sum + t.energy; }, 0) / playedTracks.length;
    const avgDance  = playedTracks.reduce(function(sum, t) { return sum + t.dance;  }, 0) / playedTracks.length;

    document.getElementById('statTracks').textContent   = playedTracks.length;
    document.getElementById('statDuration').textContent = fmtDuration(elapsedSeconds);
    document.getElementById('statEnergy').textContent   = pct(avgEnergy);
    document.getElementById('statVibe').textContent     = pct(avgDance);
  }

  // ── Add a track row to the history list ──
  function addTrackRow(track) {
    const list = document.getElementById('trackList');

    const row = document.createElement('div');
    row.className = 'track-row';
    row.innerHTML = `
      <span class="track-num">${playedTracks.length}</span>
      <img class="track-art" src="${track.imageUrl}" alt="${track.album}"/>
      <div class="track-meta">
        <p class="track-name">${track.name}</p>
        <p class="track-artist">${track.artist}</p>
      </div>
      <span class="track-dur">${fmtTrackTime(track.duration)}</span>
    `;

    // Insert at the top so newest tracks appear first
    list.insertBefore(row, list.firstChild);
  }

  // ── Load a new track ──
  function loadTrack(track) {
    // Avoid adding a duplicate if same track comes up back-to-back
    if (playedTracks.length > 0 && playedTracks[playedTracks.length - 1].id === track.id) {
      return;
    }

    playedTracks.push(track);
    updateNowPlaying(track);
    updateStats();
    addTrackRow(track);
  }

  // ── Session duration timer — ticks every second ──
  var durationInterval = setInterval(function() {
    elapsedSeconds++;
    document.getElementById('statDuration').textContent = fmtDuration(elapsedSeconds);
  }, 1000);

  // ── Simulate track changes every 8 seconds ──
  // Replaced later by polling Spotify's "currently playing" endpoint
  var trackInterval = setInterval(function() {
    trackIndex = (trackIndex + 1) % mockTracks.length;
    loadTrack(mockTracks[trackIndex]);
  }, 8000);

  // ── Load the first track immediately ──
  loadTrack(mockTracks[0]);

  // ── End session ──
  // Stops the timers, flags the playlists page to show the success banner,
  // then navigates there
  function handleEndSession() {
    clearInterval(durationInterval);
    clearInterval(trackInterval);
    sessionStorage.setItem('newPlaylist', 'true');
    // Navigation happens via the href on the end button
  }
</script>
