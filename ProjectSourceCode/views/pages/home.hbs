<!-- Beginning Styling Choices -->

<style>
  /* ── Page base ── */
  body {
    background: #000;
    color: #fff;
    font-family: 'Figtree', sans-serif;
    min-height: 100vh;
  }

  .home-wrap {
    min-height: 100vh;
    padding: 24px;
  }
  @media(min-width:768px){ .home-wrap { padding: 32px; } }

  .home-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .home-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -2.5px;
    line-height: 1.0;
    margin-bottom: 16px;
  }
  .home-subtitle {
    font-size: 1.2rem;
    color: #B3B3B3;
    max-width: 720px;
    line-height: 1.6;
  }

  /* ── Section headings ── */
  .section-heading {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 24px;
  }

  /* ── Vibe selector grid ── */
  .vibe-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  @media(min-width:640px){ .vibe-grid { grid-template-columns: repeat(3, 1fr); } }

  .vibe-btn {
    padding: 24px 20px;
    border-radius: 10px;
    background: #181818;
    border: 2px solid transparent;
    text-align: left;
    cursor: pointer;
    transition: background 0.18s, border-color 0.18s, box-shadow 0.18s, transform 0.18s;
    position: relative;
  }
  .vibe-btn:hover {
    background: #282828;
    transform: translateY(-1px);
  }
  .vibe-btn.selected {
    background: #1DB954;
    border-color: #1DB954;
    box-shadow: 0 0 0 4px rgba(29,185,84,0.2);
  }
  .vibe-emoji {
    display: block;
    font-size: 2.2rem;
    margin-bottom: 10px;
  }
  .vibe-label {
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
  }
  .vibe-btn.selected .vibe-label {
    color: #000;
  }

  /* ── Start button ── */
  .start-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 40px;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: background 0.18s, transform 0.18s, box-shadow 0.18s;
  }
  .start-btn.active {
    background: #1DB954;
    color: #000;
  }
  .start-btn.active:hover {
    background: #1ED760;
    transform: scale(1.05);
    box-shadow: 0 8px 28px rgba(29,185,84,0.3);
  }
  .start-btn.inactive {
    background: #282828;
    color: #535353;
    cursor: not-allowed;
    pointer-events: none;
  }
  .start-btn svg { flex-shrink: 0; }

  /* ── Quick access cards ── */
  .quick-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
  }
  @media(min-width:640px){ .quick-grid { grid-template-columns: repeat(2,1fr); } }

  .quick-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 24px;
    border-radius: 10px;
    background: #181818;
    border: none;
    text-align: left;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition: background 0.18s;
    width: 100%;
  }
  .quick-card:hover { background: #282828; }
  .quick-card:hover .quick-icon { transform: scale(1.1); }

  .quick-icon {
    width: 64px;
    height: 64px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.18s;
  }
  .qi-purple { background: linear-gradient(135deg, #a855f7, #ec4899); }
  .qi-blue   { background: linear-gradient(135deg, #3b82f6, #06b6d4); }

  .quick-icon svg { width: 32px; height: 32px; color: #fff; }

  .quick-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 4px;
  }
  .random-phrase {
  margin-top: 12px;
  font-size: 1.1rem;
  color: #1DB954;
  font-weight: 600;
  opacity: 0;
  animation: fadeUp 0.6s ease forwards;
  } 

  .quick-sub {
    font-size: 0.875rem;
    color: #B3B3B3;
  }

  /* ── Info / how it works box ── */
  .info-box {
    padding: 32px;
    border-radius: 10px;
    background: linear-gradient(to right, rgba(29,185,84,0.1), rgba(29,185,84,0.05));
    border: 1px solid rgba(29,185,84,0.2);
  }
  .info-box-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .info-box-title svg { color: #1DB954; width: 24px; height: 24px; flex-shrink: 0; }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media(min-width:640px){ .steps-grid { grid-template-columns: repeat(2,1fr); } }

  .step-col { display: flex; flex-direction: column; gap: 16px; }

  .step-row { display: flex; gap: 14px; }
  .step-num {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: #1DB954;
    color: #000;
    font-weight: 700;
    font-size: 0.9rem;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .step-title { font-size: 0.95rem; font-weight: 600; color: #fff; margin-bottom: 3px; }
  .step-desc  { font-size: 0.875rem; color: #B3B3B3; line-height: 1.55; }

  /* ── Spacing helpers ── */
  .mb-12 { margin-bottom: 48px; }
  .mb-16 { margin-bottom: 64px; }
  .mt-16 { margin-top: 64px; }

  /* ── Fade-up animation ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fu { animation: fadeUp 0.45s cubic-bezier(.22,.68,0,1.1) both; }
  .d1 { animation-delay: 0.08s; }
  .d2 { animation-delay: 0.16s; }
  .d3 { animation-delay: 0.24s; }
  .d4 { animation-delay: 0.32s; }

  
</style>

<!-- Beginning of Page Layout -->

<div class="home-wrap">
  <div class="home-inner">

    <!-- Header -->
   <div class="mb-12 fu">
  <h1 class="home-title" id="randomHeader"></h1>
  <p class="home-subtitle">
    Track your listening sessions and get truly personalized playlists based on your actual music preferences
  </p>
</div>

    <!-- Vibe selector -->
    <div class="mb-12 fu d1">
      <h2 class="section-heading">Choose your vibe</h2>
      <div class="vibe-grid">
        <button class="vibe-btn" data-label="Studying"   data-emoji="📚" onclick="selectVibe(this)"><span class="vibe-emoji">📚</span><span class="vibe-label">Studying</span></button>
        <button class="vibe-btn" data-label="Workout"    data-emoji="💪" onclick="selectVibe(this)"><span class="vibe-emoji">💪</span><span class="vibe-label">Workout</span></button>
        <button class="vibe-btn" data-label="Road Trip"  data-emoji="🚗" onclick="selectVibe(this)"><span class="vibe-emoji">🚗</span><span class="vibe-label">Road Trip</span></button>
        <button class="vibe-btn" data-label="Relaxing"   data-emoji="🧘" onclick="selectVibe(this)"><span class="vibe-emoji">🧘</span><span class="vibe-label">Relaxing</span></button>
        <button class="vibe-btn" data-label="Party"      data-emoji="🎉" onclick="selectVibe(this)"><span class="vibe-emoji">🎉</span><span class="vibe-label">Party</span></button>
        <button class="vibe-btn" data-label="Deep Focus" data-emoji="🎯" onclick="selectVibe(this)"><span class="vibe-emoji">🎯</span><span class="vibe-label">Deep Focus</span></button>
      </div>
    </div>

    <!-- Start session button -->
    <div class="mb-16 fu d2">
      <button class="start-btn inactive" id="startBtn" onclick="handleStart()">
        <!-- Play icon -->
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M8 5v14l11-7z"/></svg>
        Start Listening Session
      </button>
    </div>

    <!-- Quick access -->
    <div class="fu d3">
      <h2 class="section-heading">Quick access</h2>
      <div class="quick-grid">
        <a href="/playlists" class="quick-card">
          <div class="quick-icon qi-purple">
            <!-- ListMusic icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15V6"/><path d="M18.5 18a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/><path d="M12 12H3"/><path d="M16 6H3"/><path d="M12 18H3"/></svg>
          </div>
          <div>
            <p class="quick-title">Your Playlists</p>
            <p class="quick-sub">Browse your personalized mixes</p>
          </div>
        </a>

        <a href="/history" class="quick-card">
          <div class="quick-icon qi-blue">
            <!-- History icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v5h5"/><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/><path d="M12 7v5l4 2"/></svg>
          </div>
          <div>
            <p class="quick-title">Listening History</p>
            <p class="quick-sub">View past sessions and insights</p>
          </div>
        </a>
      </div>
    </div>

    <!-- How it works box -->
    <div class="info-box mt-16 fu d4">
      <h3 class="info-box-title">
        <!-- Sparkles icon -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
        How it works
      </h3>
      <div class="steps-grid">
        <div class="step-col">
          <div class="step-row">
            <div class="step-num">1</div>
            <div>
              <p class="step-title">Choose Activity</p>
              <p class="step-desc">Select what you're doing — studying, working out, or chilling</p>
            </div>
          </div>
          <div class="step-row">
            <div class="step-num">2</div>
            <div>
              <p class="step-title">Track Metadata</p>
              <p class="step-desc">We analyze audio features and listening patterns</p>
            </div>
          </div>
        </div>
        <div class="step-col">
          <div class="step-row">
            <div class="step-num">3</div>
            <div>
              <p class="step-title">Generate Playlists</p>
              <p class="step-desc">We build personalized mixes based on your taste</p>
            </div>
          </div>
          <div class="step-row">
            <div class="step-num">4</div>
            <div>
              <p class="step-title">Enjoy Your Mix</p>
