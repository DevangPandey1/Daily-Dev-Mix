<!-- Beginning Styling Choices -->

<style>
  /* ── Page base ── */
  body {
    background: #000;
    color: #fff;
    font-family: 'Figtree', sans-serif;
    min-height: 100vh;
  }

  .home-wrap {
    min-height: 100vh;
    padding: 24px;
  }
  @media(min-width:768px){ .home-wrap { padding: 32px; } }

  .home-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .home-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -2.5px;
    line-height: 1.0;
    margin-bottom: 16px;
  }
  .home-subtitle {
    font-size: 1.2rem;
    color: #B3B3B3;
    max-width: 720px;
    line-height: 1.6;
  }

  /* ── Section headings ── */
  .section-heading {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 24px;
  }

  /* ── Vibe selector grid ── */
  .vibe-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  @media(min-width:640px){ .vibe-grid { grid-template-columns: repeat(3, 1fr); } }

  .vibe-btn {
    padding: 24px 20px;
    border-radius: 10px;
    background: #181818;
    border: 2px solid transparent;
    text-align: left;
    cursor: pointer;
    transition: background 0.18s, border-color 0.18s, box-shadow 0.18s, transform 0.18s;
    position: relative;
  }
  .vibe-btn:hover {
    background: #282828;
    transform: translateY(-1px);
  }
  .vibe-btn.selected {
    background: #1DB954;
    border-color: #1DB954;
    box-shadow: 0 0 0 4px rgba(29,185,84,0.2);
  }
  .vibe-emoji {
    display: block;
    font-size: 2.2rem;
    margin-bottom: 10px;
  }
  .vibe-label {
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
  }
  .vibe-btn.selected .vibe-label {
    color: #000;
  }

  .trash-icon {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(0, 0, 0, 0.7);
    border-radius: 50%;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 10;
  }
  .vibe-btn:hover .trash-icon {
    opacity: 1;
  }
  .trash-icon:hover {
    background: rgba(0, 0, 0, 0.9);
  }

  .create-topic-btn {
    background: #1E1E1E;
    border-color: #5C5C5C;
  }
  .create-topic-btn:hover {
    background: #2A2A2A;
  }

  .modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
    padding: 24px;
    z-index: 1000;
  }
  .modal-backdrop.open {
    display: flex;
  }
  .modal-card {
    width: min(520px, 100%);
    background: #0f0f0f;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 28px;
    box-shadow: 0 24px 48px rgba(0,0,0,0.35);
  }
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }
  .modal-header h3 {
    font-size: 1.4rem;
    margin: 0;
  }
  .modal-close {
    border: none;
    background: transparent;
    color: #fff;
    font-size: 1.2rem;
    cursor: pointer;
  }
  .modal-description {
    color: #B3B3B3;
    margin-bottom: 20px;
    line-height: 1.5;
  }
  .modal-label {
    display: block;
    color: #fff;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .modal-input {
    width: 100%;
    padding: 14px 16px;
    border-radius: 12px;
    background: #111;
    border: 1px solid #2B2B2B;
    color: #fff;
    margin-bottom: 8px;
    font-size: 1rem;
  }
  .modal-hint {
    color: #6B6B6B;
    margin-bottom: 18px;
    font-size: 0.92rem;
  }
  .emoji-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-bottom: 16px;
  }
  .emoji-option {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 14px;
    border-radius: 14px;
    border: 1px solid #2B2B2B;
    background: #111;
    color: #fff;
    font-size: 1.3rem;
    cursor: pointer;
  }
  .emoji-option.selected {
    border-color: #1DB954;
    box-shadow: 0 0 0 3px rgba(29,185,84,0.15);
  }
  .modal-error {
    color: #ff6b6b;
    min-height: 20px;
    margin-bottom: 12px;
    font-size: 0.95rem;
  }
  .modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    flex-wrap: wrap;
  }
  .modal-button {
    border: none;
    border-radius: 999px;
    padding: 14px 24px;
    font-weight: 700;
    cursor: pointer;
  }
  .modal-button.primary {
    background: #1DB954;
    color: #000;
  }
  .modal-button.cancel {
    background: #202020;
    color: #fff;
  }

  /* ── Start button ── */
  .start-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 40px;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: background 0.18s, transform 0.18s, box-shadow 0.18s;
  }
  .start-btn.active {
    background: #1DB954;
    color: #000;
  }
  .start-btn.active:hover {
    background: #1ED760;
    transform: scale(1.05);
    box-shadow: 0 8px 28px rgba(29,185,84,0.3);
  }
  .start-btn.inactive {
    background: #282828;
    color: #535353;
    cursor: not-allowed;
    pointer-events: none;
  }
  .start-btn svg { flex-shrink: 0; }

  /* ── Quick access cards ── */
  .quick-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
  }
  @media(min-width:640px){ .quick-grid { grid-template-columns: repeat(2,1fr); } }

  .quick-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 24px;
    border-radius: 10px;
    background: #181818;
    border: none;
    text-align: left;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition: background 0.18s;
    width: 100%;
  }
  .quick-card:hover { background: #282828; }
  .quick-card:hover .quick-icon { transform: scale(1.1); }

  .quick-icon {
    width: 64px;
    height: 64px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.18s;
  }
  .qi-purple { background: linear-gradient(135deg, #a855f7, #ec4899); }
  .qi-blue   { background: linear-gradient(135deg, #3b82f6, #06b6d4); }

  .quick-icon svg { width: 32px; height: 32px; color: #fff; }

  .quick-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 4px;
  }
  .quick-sub {
    font-size: 0.875rem;
    color: #B3B3B3;
  }

  /* ── Info / how it works box ── */
  .info-box {
    padding: 32px;
    border-radius: 10px;
    background: linear-gradient(to right, rgba(29,185,84,0.1), rgba(29,185,84,0.05));
    border: 1px solid rgba(29,185,84,0.2);
  }
  .info-box-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .info-box-title svg { color: #1DB954; width: 24px; height: 24px; flex-shrink: 0; }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media(min-width:640px){ .steps-grid { grid-template-columns: repeat(2,1fr); } }

  .step-col { display: flex; flex-direction: column; gap: 16px; }

  .step-row { display: flex; gap: 14px; }
  .step-num {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: #1DB954;
    color: #000;
    font-weight: 700;
    font-size: 0.9rem;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .step-title { font-size: 0.95rem; font-weight: 600; color: #fff; margin-bottom: 3px; }
  .step-desc  { font-size: 0.875rem; color: #B3B3B3; line-height: 1.55; }

  /* ── Spacing helpers ── */
  .mb-12 { margin-bottom: 48px; }
  .mb-16 { margin-bottom: 64px; }
  .mt-16 { margin-top: 64px; }

  /* ── Fade-up animation ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fu { animation: fadeUp 0.45s cubic-bezier(.22,.68,0,1.1) both; }
  .d1 { animation-delay: 0.08s; }
  .d2 { animation-delay: 0.16s; }
  .d3 { animation-delay: 0.24s; }
  .d4 { animation-delay: 0.32s; }
</style>

<!-- Beginning of Page Layout -->

<div class="home-wrap">
  <div class="home-inner">

    <!-- Header -->
    <div class="mb-12 fu">
      <h1 class="home-title">Daily Dev Mix</h1>
      <p class="home-subtitle">
        Track your listening sessions and get truly personalized playlists based on your actual music preferences
      </p>
    </div>

