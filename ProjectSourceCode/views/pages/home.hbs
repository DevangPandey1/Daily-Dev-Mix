<!-- Beginning of Script Code and Functions -->

<script>
  const storageKey = 'customListeningTopics';
  const vibeGrid = document.getElementById('vibeGrid');
  const topicModal = document.getElementById('topicModal');
  const topicName = document.getElementById('topicName');
  const topicEmoji = document.getElementById('topicEmoji');
  const topicError = document.getElementById('topicError');
  const startBtn = document.getElementById('startBtn');

  const getCustomTopics = () => {
    try {
      return JSON.parse(localStorage.getItem(storageKey) || '[]');
    } catch {
      return [];
    }
  };

  const saveCustomTopics = (topics) => {
    localStorage.setItem(storageKey, JSON.stringify(topics));
  };

  const activateStartButton = () => {
    startBtn.classList.replace('inactive', 'active');
  };

  const selectVibe = (btn) => {
    document.querySelectorAll('.vibe-btn').forEach((item) => item.classList.remove('selected'));
    btn.classList.add('selected');

    sessionStorage.setItem('selectedLabel', btn.dataset.label);
    sessionStorage.setItem('selectedEmoji', btn.dataset.emoji);
    activateStartButton();
  };

  const handleStart = () => {
    if (sessionStorage.getItem('selectedLabel')) {
      window.location.href = '/active-session';
    }
  };

  const renderCustomTopics = () => {
    vibeGrid.querySelectorAll('.vibe-btn.custom-topic').forEach((node) => node.remove());
    const anchor = vibeGrid.querySelector('.create-topic-btn');
    getCustomTopics().forEach(({ label, emoji }) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'vibe-btn custom-topic';
      btn.dataset.label = label;
      btn.dataset.emoji = emoji;
      btn.onclick = () => selectVibe(btn);
      btn.innerHTML = `<span class="vibe-emoji">${emoji}</span><span class="vibe-label">${label}</span><div class="trash-icon" onclick="removeVibe('${label}', event)">🗑️</div>`;
      vibeGrid.insertBefore(btn, anchor);
    });
  };

  const resetModal = () => {
    topicName.value = '';
    topicEmoji.value = '';
    topicError.textContent = '';
    document.querySelectorAll('.emoji-option').forEach((el) => el.classList.remove('selected'));
  };

  const openTopicModal = () => {
    resetModal();
    topicModal.classList.add('open');
  };

  const closeTopicModal = (event) => {
    event?.preventDefault();
    topicModal.classList.remove('open');
  };

  const selectTopicEmoji = (btn) => {
    document.querySelectorAll('.emoji-option').forEach((el) => el.classList.remove('selected'));
    btn.classList.add('selected');
    topicEmoji.value = btn.textContent.trim();
  };

  const handleTopicSubmit = (event) => {
    event.preventDefault();
    const name = topicName.value.trim();
    const emoji = topicEmoji.value.trim();

    if (!name) {
      topicError.textContent = 'Please enter a topic name.';
      return;
    }
    if (name.length > 30) {
      topicError.textContent = 'Topic name must be 30 characters or fewer.';
      return;
    }
    if (!emoji) {
      topicError.textContent = 'Please choose an emoji for the topic.';
      return;
    }

    const topics = getCustomTopics();
    topics.push({ label: name, emoji });
    saveCustomTopics(topics);
    renderCustomTopics();
    closeTopicModal();

    const newBtn = Array.from(vibeGrid.querySelectorAll('.vibe-btn.custom-topic')).find(
      (btn) => btn.dataset.label === name && btn.dataset.emoji === emoji
    );
    if (newBtn) selectVibe(newBtn);
  };

  const removeVibe = (label, event) => {
    event.stopPropagation();
    const btn = event.target.closest('.vibe-btn');
    if (btn) {
      btn.style.display = 'none';
    }
    if (sessionStorage.getItem('selectedLabel') === label) {
      sessionStorage.removeItem('selectedLabel');
      sessionStorage.removeItem('selectedEmoji');
      document.querySelectorAll('.vibe-btn').forEach((item) => item.classList.remove('selected'));
      startBtn.classList.replace('active', 'inactive');
    }
    // For custom topics, remove from storage
    const customTopics = getCustomTopics();
    const filtered = customTopics.filter(topic => topic.label !== label);
    if (filtered.length !== customTopics.length) {
      saveCustomTopics(filtered);
    }
  };

  window.addEventListener('DOMContentLoaded', () => {
    renderCustomTopics();
    const storedLabel = sessionStorage.getItem('selectedLabel');
    const storedEmoji = sessionStorage.getItem('selectedEmoji');

    if (storedLabel && storedEmoji) {
      const match = Array.from(document.querySelectorAll('.vibe-btn')).find(
        (btn) => btn.dataset.label === storedLabel && btn.dataset.emoji === storedEmoji
      );
      if (match) {
        match.classList.add('selected');
        activateStartButton();
      }
    }
  });
</script>