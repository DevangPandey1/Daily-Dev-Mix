        <button class="vibe-btn" data-label="Studying" data-emoji="📚" onclick="selectVibe(this)"><span class="vibe-emoji">📚</span><span class="vibe-label">Studying</span><div class="trash-icon" onclick="removeVibe('Studying', event)">🗑️</div></button>
        <button class="vibe-btn" data-label="Workout" data-emoji="💪" onclick="selectVibe(this)"><span class="vibe-emoji">💪</span><span class="vibe-label">Workout</span><div class="trash-icon" onclick="removeVibe('Workout', event)">🗑️</div></button>
        <button class="vibe-btn" data-label="Road Trip" data-emoji="🚗" onclick="selectVibe(this)"><span class="vibe-emoji">🚗</span><span class="vibe-label">Road Trip</span><div class="trash-icon" onclick="removeVibe('Road Trip', event)">🗑️</div></button>
        <button class="vibe-btn" data-label="Relaxing" data-emoji="🧘" onclick="selectVibe(this)"><span class="vibe-emoji">🧘</span><span class="vibe-label">Relaxing</span><div class="trash-icon" onclick="removeVibe('Relaxing', event)">🗑️</div></button>
        <button class="vibe-btn" data-label="Party" data-emoji="🎉" onclick="selectVibe(this)"><span class="vibe-emoji">🎉</span><span class="vibe-label">Party</span><div class="trash-icon" onclick="removeVibe('Party', event)">🗑️</div></button>
