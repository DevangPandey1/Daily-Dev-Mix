            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">🎸</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">🎤</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">🎯</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">💬</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">😌</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">🚀</button>
