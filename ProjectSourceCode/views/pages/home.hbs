            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Beginning of Script Code and Functions -->

<script>
  let selectedVibe = null;

  function selectVibe(btn) {
    document.querySelectorAll('.vibe-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    selectedVibe = btn.dataset.label;

    // Save for other pages
    sessionStorage.setItem('selectedLabel', btn.dataset.label);
    sessionStorage.setItem('selectedEmoji', btn.dataset.emoji);

    // Activate start button
    const startBtn = document.getElementById('startBtn');
    startBtn.classList.replace('inactive', 'active');
  }

  function handleStart() {
    if (selectedVibe) {
      window.location.href = '/active-session';
    }
  }
  const phrases = [
  "Welcome back",
  "Holy playlist aura",
  "Your vibe is unmatched today",
  "Music that understands you",
  "Press play on your mood",
  "This session is about to hit different",
  "Today's vibe: curated perfection"
];

function updateHeader() {
    const header = document.getElementById("randomHeader");
    if (!header) return;
    const random = phrases[Math.floor(Math.random() * phrases.length)];
    header.textContent = random;
  }

  // Initialize on load

  window.onload = updateHeader;
</script>

