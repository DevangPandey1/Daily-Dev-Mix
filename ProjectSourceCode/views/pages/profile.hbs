<style>
  body {
    background: #000;
    color: #fff;
    font-family: 'Figtree', sans-serif;
    min-height: 100vh;
    margin: 0;
  }

  .page-wrap {
    min-height: 100vh;
    padding: 24px;
  }
  @media (min-width: 768px) {
    .page-wrap { padding: 32px; }
  }

  .page-inner {
    max-width: 1180px;
    margin: 0 auto;
  }

  .profile-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 28px;
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,0.08);
    background:
      radial-gradient(circle at top right, rgba(29,185,84,0.22), transparent 36%),
      linear-gradient(145deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
    margin-bottom: 24px;
  }
  @media (min-width: 900px) {
    .profile-hero {
      grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.8fr);
      align-items: center;
    }
  }

  .hero-identity {
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }

  .profile-avatar {
    width: 76px;
    height: 76px;
    border-radius: 24px;
    background: linear-gradient(135deg, #1DB954, #1ED760);
    color: #04110a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 900;
    flex-shrink: 0;
  }

  .profile-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(29,185,84,0.12);
    border: 1px solid rgba(29,185,84,0.24);
    color: #86efac;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }

  .profile-title {
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 0.95;
    margin-bottom: 12px;
  }

  .profile-subtitle {
    color: #B3B3B3;
    font-size: 1rem;
    line-height: 1.7;
    max-width: 700px;
  }

  .hero-meta {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .meta-card {
    padding: 18px;
    border-radius: 18px;
    background: rgba(0,0,0,0.28);
    border: 1px solid rgba(255,255,255,0.06);
  }

  .meta-label {
    color: #B3B3B3;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 10px;
  }

  .meta-value {
    font-size: 1.05rem;
    font-weight: 700;
    word-break: break-word;
  }

  .overview-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 18px;
    margin-bottom: 24px;
  }
  @media (min-width: 768px) {
    .overview-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .overview-card {
    padding: 22px;
    border-radius: 20px;
    background: #181818;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .overview-icon {
    width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    margin-bottom: 16px;
    background: rgba(29,185,84,0.12);
    color: #1ED760;
  }

  .overview-value {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    margin-bottom: 6px;
  }

  .overview-label {
    color: #B3B3B3;
    font-size: 0.88rem;
  }

  .section-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 960px) {
    .section-grid {
      grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    }
  }

  .section-card {
    padding: 24px;
    border-radius: 22px;
    background: #121212;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .section-title {
    font-size: 1.35rem;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .section-copy {
    color: #B3B3B3;
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 18px;
  }

  .scope-group + .scope-group {
    margin-top: 20px;
  }

  .scope-heading {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #D1D5DB;
    margin-bottom: 12px;
  }

  .scope-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .scope-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-radius: 999px;
    font-size: 0.86rem;
    font-weight: 600;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.04);
  }

  .scope-pill.granted {
    border-color: rgba(29,185,84,0.26);
    background: rgba(29,185,84,0.12);
    color: #86efac;
  }

  .scope-pill.missing {
    border-color: rgba(250,204,21,0.24);
    background: rgba(250,204,21,0.1);
    color: #fde68a;
  }

  .scope-empty {
    color: #B3B3B3;
    line-height: 1.6;
  }

  .action-stack {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .action-panel {
    padding: 18px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.02);
  }

  .action-label {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .action-copy {
    color: #B3B3B3;
    font-size: 0.92rem;
    line-height: 1.6;
    margin-bottom: 14px;
  }

  .action-btn {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 18px;
    border-radius: 999px;
    border: none;
    font-weight: 700;
    transition: transform 0.18s, background 0.18s;
  }

  .action-btn:hover {
    transform: translateY(-1px);
  }

  .action-btn.primary {
    background: #1DB954;
    color: #04110a;
  }

  .action-btn.primary:hover {
    background: #1ED760;
  }

  .action-btn.secondary {
    background: #202020;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .action-btn.secondary:hover {
    background: #2a2a2a;
  }

  .action-btn.danger {
    background: rgba(239,68,68,0.14);
    color: #fca5a5;
    border: 1px solid rgba(239,68,68,0.24);
  }

  .action-btn.danger:hover {
    background: rgba(239,68,68,0.2);
  }

  .page-message {
    margin-bottom: 20px;
  }
</style>

{{> nav}}

<div class="page-wrap">
  <div class="page-inner">
    <div class="page-message">
      {{> message}}
    </div>

    <section class="profile-hero">
      <div>
        <div class="hero-identity">
          <div class="profile-avatar">{{profileInitial}}</div>
          <div>
            <div class="profile-kicker">Profile And Settings</div>
            <h1 class="profile-title">{{profileDisplayName}}</h1>
            <p class="profile-subtitle">
              Manage your connected Spotify account, review the permissions Daily Dev Mix is using,
              and control whether this browser stays signed in for playlist generation and listening history.
            </p>
          </div>
        </div>
      </div>

      <div class="hero-meta">
        <div class="meta-card">
          <div class="meta-label">Spotify ID</div>
          <div class="meta-value">
            {{#if profile.id}}{{profile.id}}{{else}}Not available yet{{/if}}
          </div>
        </div>
        <div class="meta-card">
          <div class="meta-label">Plan</div>
          <div class="meta-value">{{spotifyPlanLabel}}</div>
        </div>
        <div class="meta-card">
          <div class="meta-label">Country</div>
          <div class="meta-value">{{countryLabel}}</div>
        </div>
        <div class="meta-card">
          <div class="meta-label">Active Session</div>
          <div class="meta-value">
            {{#if activeSessionLabel}}{{activeSessionLabel}}{{else}}No live session{{/if}}
          </div>
        </div>
      </div>
    </section>

    <section class="overview-grid">
      <div class="overview-card">
        <div class="overview-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
            <path d="M9 18V5l12-2v13"></path>
            <circle cx="6" cy="18" r="3"></circle>
            <circle cx="18" cy="16" r="3"></circle>
          </svg>
        </div>
        <div class="overview-value">{{generatedPlaylistCount}}</div>
        <div class="overview-label">Generated playlists cached in this app session</div>
      </div>

      <div class="overview-card">
        <div class="overview-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
            <path d="M3 3v5h5"></path>
            <path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"></path>
            <path d="M12 7v5l4 2"></path>
          </svg>
        </div>
        <div class="overview-value">{{sessionHistoryCount}}</div>
        <div class="overview-label">Completed listening sessions saved in this browser session</div>
      </div>

      <div class="overview-card">
        <div class="overview-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <div class="overview-value">{{grantedScopeCount}} / {{requiredScopeCount}}</div>
        <div class="overview-label">
          Spotify scopes available to the app
          {{#if missingScopeCount}}with {{missingScopeCount}} still missing{{/if}}
        </div>
      </div>
    </section>

    <section class="section-grid">
      <div class="section-card">
        <h2 class="section-title">Spotify Permissions</h2>
        <p class="section-copy">
          These scopes determine what Daily Dev Mix can read or change. If anything below is missing,
          signing in again with Spotify will prompt the app to request it.
        </p>

        <div class="scope-group">
          <div class="scope-heading">Granted</div>
          {{#if grantedScopeCount}}
            <div class="scope-list">
              {{#each grantedScopes}}
                <span class="scope-pill granted">{{this}}</span>
              {{/each}}
            </div>
          {{else}}
            <p class="scope-empty">No Spotify scopes are cached for this session yet.</p>
          {{/if}}
        </div>

        <div class="scope-group">
          <div class="scope-heading">Missing</div>
          {{#if missingScopeCount}}
            <div class="scope-list">
              {{#each missingScopes}}
                <span class="scope-pill missing">{{this}}</span>
              {{/each}}
            </div>
          {{else}}
            <p class="scope-empty">All required Spotify permissions are currently available.</p>
          {{/if}}
        </div>
      </div>

      <div class="section-card">
        <h2 class="section-title">Session Actions</h2>
        <p class="section-copy">
          Use logout if you just want to leave the app on this browser. Use disconnect if you want
          Daily Dev Mix to forget the current Spotify session data completely.
        </p>

        <div class="action-stack">
          <div class="action-panel">
            <div class="action-label">Log Out</div>
            <div class="action-copy">
              End this Daily Dev Mix session and return to the Spotify sign-in screen.
            </div>
            <form method="POST" action="/logout">
              <button type="submit" class="action-btn secondary">Log Out Of Daily Dev Mix</button>
            </form>
          </div>

          <div class="action-panel">
            <div class="action-label">Disconnect Spotify</div>
            <div class="action-copy">
              Clear the current Spotify tokens, listening session cache, and generated playlist cache from this browser session.
            </div>
            <form method="POST" action="/disconnect" onsubmit="return window.confirm('This clears the current Spotify connection from Daily Dev Mix on this browser. Continue?');">
              <button type="submit" class="action-btn danger">Disconnect Spotify Session</button>
            </form>
          </div>

          <div class="action-panel">
            <div class="action-label">Resume Building</div>
            <div class="action-copy">
              Your library, history, and live session pages remain available as long as this app session stays connected.
            </div>
            <a href="/playlists" class="action-btn primary">Open Playlist Library</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>
