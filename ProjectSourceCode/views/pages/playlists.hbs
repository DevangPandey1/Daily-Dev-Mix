<!-- Beginning Styling Choices -->

<style>
  /* ── Base ── */
  body {
    background: #000;
    color: #fff;
    font-family: 'Figtree', sans-serif;
    min-height: 100vh;
    margin: 0;
    -webkit-font-smoothing: antialiased;
  }

  .page-wrap {
    min-height: 100vh;
    padding: 24px;
  }
  @media(min-width:768px){ .page-wrap { padding: 32px; } }

  .page-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ── Header row ── */
  .header-row {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
  }

  .back-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(0,0,0,0.4);
    border: 1px solid #282828;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    text-decoration: none;
    flex-shrink: 0;
    transition: background 0.18s;
    font-size: 1.1rem;
  }
  .back-btn:hover { background: #282828; }

  .page-title {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -2px;
    line-height: 1.0;
    margin-bottom: 8px;
  }
  .page-subtitle {
    font-size: 1.1rem;
    color: #B3B3B3;
  }

  /* ── Success banner ── */
  .success-banner {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px;
    border-radius: 10px;
    background: rgba(29,185,84,0.1);
    border: 1px solid rgba(29,185,84,0.3);
    margin-bottom: 32px;
    /* Hidden by default, shown via JS */
    display: none;
  }
  .success-banner.visible { display: flex; }
  .banner-check {
    color: #1DB954;
    flex-shrink: 0;
  }
  .banner-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 2px;
  }
  .banner-sub {
    font-size: 0.875rem;
    color: #B3B3B3;
  }

  .library-message {
    display: none;
    margin-bottom: 24px;
    padding: 16px 18px;
    border-radius: 12px;
    border: 1px solid #282828;
    background: #161616;
    line-height: 1.55;
  }
  .library-message.visible { display: block; }
  .library-message.success {
    border-color: rgba(29,185,84,0.35);
    background: rgba(29,185,84,0.12);
  }
  .library-message.error {
    border-color: rgba(248,113,113,0.35);
    background: rgba(127,29,29,0.35);
  }
  .library-message.info {
    border-color: rgba(96,165,250,0.35);
    background: rgba(59,130,246,0.12);
  }

  .library-controls {
    display: none;
    grid-template-columns: minmax(0, 1.4fr) minmax(220px, 0.6fr) auto;
    gap: 14px;
    align-items: center;
    margin-bottom: 28px;
  }
  @media(max-width:840px) {
    .library-controls {
      grid-template-columns: 1fr;
    }
  }

  .search-shell,
  .sort-shell {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 14px;
    background: #151515;
    border: 1px solid #282828;
  }
  .search-shell svg,
  .sort-shell svg {
    flex-shrink: 0;
    color: #B3B3B3;
  }
  .search-input,
  .sort-select {
    width: 100%;
    border: none;
    background: transparent;
    color: #fff;
    font-size: 0.95rem;
    outline: none;
  }
  .sort-select option {
    background: #111;
  }

  .results-note {
    justify-self: end;
    color: #B3B3B3;
    font-size: 0.9rem;
  }
  @media(max-width:840px) {
    .results-note {
      justify-self: start;
    }
  }

  /* ── Empty state ── */
  .empty-state {
    text-align: center;
    padding: 96px 0;
    display: none;
  }
  .empty-state.visible { display: block; }
  .empty-icon {
    width: 96px; height: 96px;
    border-radius: 50%;
    background: #282828;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 24px;
    font-size: 2.5rem;
  }
  .empty-title {
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 12px;
  }
  .empty-desc {
    font-size: 1.05rem;
    color: #B3B3B3;
    max-width: 400px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }
  .btn-green {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 32px;
    border-radius: 999px;
    background: #1DB954;
    color: #000;
    font-size: 1rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.18s, transform 0.18s;
  }
  .btn-green:hover { background: #1ED760; transform: scale(1.05); }

  /* ── Playlist grid ── */
  .playlist-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: repeat(2, 1fr);
  }
  @media(min-width:640px)  { .playlist-grid { grid-template-columns: repeat(3, 1fr); } }
  @media(min-width:1024px) { .playlist-grid { grid-template-columns: repeat(4, 1fr); } }
  @media(min-width:1280px) { .playlist-grid { grid-template-columns: repeat(5, 1fr); } }

  /* ── Playlist card ── */
  .playlist-card {
    padding: 16px;
    border-radius: 10px;
    background: #181818;
    cursor: pointer;
    transition: background 0.18s, transform 0.18s;
    position: relative;
  }
  .playlist-card:hover {
    background: #282828;
    transform: scale(1.02);
  }

  /* Play button appears on hover */
  .playlist-card:hover .play-btn { opacity: 1; transform: translateY(0); }

  .art-wrap {
    position: relative;
    margin-bottom: 16px;
  }
  .playlist-art {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 6px;
    object-fit: cover;
    display: block;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    /* Fallback background if image fails */
    background: #282828;
  }
  .playlist-placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    background: linear-gradient(135deg, rgba(29,185,84,0.3), rgba(29,185,84,0.08));
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }
  .play-btn {
    position: absolute;
    bottom: 8px; right: 8px;
    width: 46px; height: 46px;
    border-radius: 50%;
    background: #1DB954;
    border: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.5);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.2s, transform 0.2s;
  }
  .play-btn svg { color: #000; width: 20px; height: 20px; margin-left: 2px; }
  .playlist-card.new-playlist {
    box-shadow: 0 0 0 1px rgba(29,185,84,0.45), 0 16px 28px rgba(29,185,84,0.12);
  }
  .playlist-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }
  .playlist-action-btn {
    border: none;
    border-radius: 999px;
    padding: 10px 14px;
    font-size: 0.78rem;
    font-weight: 700;
    transition: transform 0.18s, background 0.18s;
  }
  .playlist-action-btn:hover {
    transform: translateY(-1px);
  }
  .playlist-action-btn.open {
    background: rgba(29,185,84,0.16);
    color: #86efac;
  }
  .playlist-action-btn.share,
  .playlist-action-btn.rename {
    background: #222;
    color: #fff;
  }
  .playlist-action-btn.remove {
    background: rgba(239,68,68,0.15);
    color: #fca5a5;
  }
  .playlist-open-hint {
    margin-top: 12px;
    color: #7d7d7d;
    font-size: 0.78rem;
  }

  .filter-empty {
    display: none;
    padding: 48px 28px;
    border-radius: 18px;
    border: 1px dashed rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.02);
    color: #B3B3B3;
    line-height: 1.7;
    text-align: center;
  }
  .filter-empty.visible { display: block; }

  .playlist-name {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 6px;
    /* Truncate long names to one line */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .playlist-desc {
    font-size: 0.82rem;
    color: #B3B3B3;
    margin-bottom: 12px;
    line-height: 1.45;
    /* Clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .playlist-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: #B3B3B3;
  }
  .playlist-meta svg { width: 12px; height: 12px; flex-shrink: 0; }

  /* ── Info box ── */
  .info-box {
    margin-top: 64px;
    padding: 32px;
    border-radius: 10px;
    background: linear-gradient(to right, rgba(29,185,84,0.05), transparent);
    border: 1px solid #282828;
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .info-box-icon {
    color: #1DB954;
    flex-shrink: 0;
    margin-top: 2px;
    width: 32px; height: 32px;
  }
  .info-box-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .info-box-text {
    color: #B3B3B3;
    font-size: 0.9rem;
    line-height: 1.75;
  }

  .rename-modal-shell {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: rgba(0,0,0,0.72);
    backdrop-filter: blur(12px);
    z-index: 2000;
  }
  .rename-modal-shell.visible { display: flex; }

  .rename-modal {
    width: min(100%, 460px);
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,0.08);
    background: linear-gradient(180deg, rgba(20,20,20,0.98), rgba(12,12,12,0.98));
    padding: 24px;
    box-shadow: 0 24px 72px rgba(0,0,0,0.45);
  }

  .rename-title {
    font-size: 1.35rem;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .rename-copy {
    color: #B3B3B3;
    line-height: 1.6;
    margin-bottom: 18px;
  }

  .rename-label {
    display: block;
    font-size: 0.86rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: #D1D5DB;
  }

  .rename-input {
    width: 100%;
    border-radius: 14px;
    border: 1px solid #2f2f2f;
    background: #101010;
    color: #fff;
    padding: 14px 16px;
    font-size: 0.98rem;
    outline: none;
  }
  .rename-input:focus {
    border-color: rgba(29,185,84,0.55);
    box-shadow: 0 0 0 4px rgba(29,185,84,0.12);
  }

  .rename-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 18px;
  }

  .modal-btn {
    border: none;
    border-radius: 999px;
    padding: 12px 18px;
    font-weight: 700;
    transition: transform 0.18s, background 0.18s;
  }
  .modal-btn:hover { transform: translateY(-1px); }
  .modal-btn.cancel {
    background: #242424;
    color: #fff;
  }
  .modal-btn.save {
    background: #1DB954;
    color: #04110a;
  }

  /* ── Fade-up animation ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fu { animation: fadeUp 0.45s cubic-bezier(.22,.68,0,1.1) both; }
  .d1 { animation-delay: 0.08s; }
  .d2 { animation-delay: 0.16s; }
  .d3 { animation-delay: 0.24s; }
</style>

