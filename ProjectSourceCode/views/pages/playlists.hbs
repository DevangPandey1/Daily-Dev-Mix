<!-- Beginning of Script Code and Functions -->

<script>
  let allPlaylists = [];
  let renameTargetId = null;

  const searchInput = document.getElementById('playlistSearch');
  const sortSelect = document.getElementById('playlistSort');
  const resultsNote = document.getElementById('resultsNote');
  const libraryMessage = document.getElementById('libraryMessage');
  const renameModal = document.getElementById('renameModal');
  const renameForm = document.getElementById('renameForm');
  const renameInput = document.getElementById('renameInput');
  const renameTargetTitle = document.getElementById('renameTargetTitle');
  const renameCancelBtn = document.getElementById('renameCancelBtn');
  const renameSubmitBtn = document.getElementById('renameSubmitBtn');

  function openPlaylist(desktopUrl, webUrl) {
    if (!desktopUrl && !webUrl) {
      return;
    }

    if (!desktopUrl) {
      window.location.assign(webUrl);
      return;
    }

    let cleanedUp = false;
    let fallbackTimer = null;
    let appLaunchObserved = false;

    function cleanup() {
      if (cleanedUp) {
        return;
      }

      cleanedUp = true;
      if (fallbackTimer) {
        window.clearTimeout(fallbackTimer);
      }

      window.removeEventListener('blur', cancelFallback);
      window.removeEventListener('pagehide', cancelFallback);
      document.removeEventListener('visibilitychange', cancelFallback);
    }

    function cancelFallback() {
      if (
        document.hidden ||
        document.visibilityState === 'hidden' ||
        document.hasFocus() === false
      ) {
        appLaunchObserved = true;
        cleanup();
      }
    }

    window.addEventListener('blur', cancelFallback, { once: true });
    window.addEventListener('pagehide', cancelFallback, { once: true });
    document.addEventListener('visibilitychange', cancelFallback);

    fallbackTimer = window.setTimeout(function() {
      cleanup();

      if (!appLaunchObserved && webUrl) {
        window.location.assign(webUrl);
      }
    }, 2200);

    const launcherLink = document.createElement('a');
    launcherLink.href = desktopUrl;
    launcherLink.style.display = 'none';
    document.body.appendChild(launcherLink);
    launcherLink.click();
    launcherLink.remove();
  }

  function showLibraryMessage(message, type) {
    if (!message) {
      libraryMessage.textContent = '';
      libraryMessage.className = 'library-message';
      return;
    }

    libraryMessage.textContent = message;
    libraryMessage.className = 'library-message visible ' + (type || 'info');
  }

  function getPlaylistCountLabel(count) {
    return count === 1 ? '1 playlist' : count + ' playlists';
  }

  function updateResultsNote(filteredCount, totalCount) {
    if (!totalCount) {
      resultsNote.textContent = '0 playlists';
      return;
    }

    if (filteredCount === totalCount) {
      resultsNote.textContent = getPlaylistCountLabel(totalCount);
      return;
    }

    resultsNote.textContent = filteredCount + ' of ' + totalCount + ' playlists';
  }

  function sortPlaylists(playlists) {
    const nextPlaylists = playlists.slice();
    const sortValue = sortSelect.value;

    if (sortValue === 'name-desc') {
      return nextPlaylists.sort(function(a, b) {
        return b.name.localeCompare(a.name);
      });
    }

    if (sortValue === 'tracks-desc') {
      return nextPlaylists.sort(function(a, b) {
        return b.trackCount - a.trackCount || a.name.localeCompare(b.name);
      });
    }

    if (sortValue === 'tracks-asc') {
      return nextPlaylists.sort(function(a, b) {
        return a.trackCount - b.trackCount || a.name.localeCompare(b.name);
      });
    }

    return nextPlaylists.sort(function(a, b) {
      return a.name.localeCompare(b.name);
    });
  }

  function getVisiblePlaylists() {
    const searchTerm = searchInput.value.trim().toLowerCase();
    const filtered = allPlaylists.filter(function(playlist) {
      if (!searchTerm) {
        return true;
      }

      return [playlist.name, playlist.description]
        .join(' ')
        .toLowerCase()
        .includes(searchTerm);
    });

    return sortPlaylists(filtered);
  }

  function buildActionButton(label, className, onClick) {
    const button = document.createElement('button');
    button.type = 'button';
    button.className = 'playlist-action-btn ' + className;
    button.textContent = label;
    button.addEventListener('click', function(event) {
      event.stopPropagation();
      const maybePromise = onClick(event);
      if (maybePromise && typeof maybePromise.catch === 'function') {
        maybePromise.catch(function(error) {
          showLibraryMessage(error.message || 'That playlist action could not be completed.', 'error');
        });
      }
    });
    return button;
  }

  function createPlaylistCard(playlist, lastCreatedPlaylistId) {
    const card = document.createElement('div');
    card.className = 'playlist-card';
    if (playlist.id === lastCreatedPlaylistId) {
      card.classList.add('new-playlist');
    }
    card.addEventListener('click', function() {
      openPlaylist(playlist.desktopUrl, playlist.externalUrl);
    });

    const artWrap = document.createElement('div');
    artWrap.className = 'art-wrap';

    if (playlist.imageUrl) {
      const image = document.createElement('img');
      image.className = 'playlist-art';
      image.src = playlist.imageUrl;
      image.alt = playlist.name;
      artWrap.appendChild(image);
    } else {
      const placeholder = document.createElement('div');
      placeholder.className = 'playlist-placeholder';
      placeholder.textContent = '🎧';
      artWrap.appendChild(placeholder);
    }

    const playButton = document.createElement('button');
    playButton.className = 'play-btn';
    playButton.type = 'button';
    playButton.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>';
    playButton.addEventListener('click', function(event) {
      event.stopPropagation();
      openPlaylist(playlist.desktopUrl, playlist.externalUrl);
    });
    artWrap.appendChild(playButton);

    const title = document.createElement('p');
    title.className = 'playlist-name';
    title.textContent = playlist.name;

    const description = document.createElement('p');
    description.className = 'playlist-desc';
    description.textContent = playlist.description || 'Generated from one of your Daily Dev Mix listening sessions.';

    const meta = document.createElement('div');
    meta.className = 'playlist-meta';
    meta.innerHTML = `
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
      <span>${playlist.trackCount} songs</span>
      <span>•</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1v22"/><path d="M17 5H9a4 4 0 0 0 0 8h6a4 4 0 1 1 0 8H7"/></svg>
      <span>${playlist.isPublic ? 'Public' : 'Private'}</span>
    `;

    const actions = document.createElement('div');
    actions.className = 'playlist-actions';
    actions.appendChild(buildActionButton('Open', 'open', function() {
      openPlaylist(playlist.desktopUrl, playlist.externalUrl);
    }));
    actions.appendChild(buildActionButton('Share', 'share', function() {
      sharePlaylist(playlist);
    }));
    actions.appendChild(buildActionButton('Rename', 'rename', function() {
      openRenameModal(playlist);
    }));
    actions.appendChild(buildActionButton('Remove', 'remove', function() {
      removePlaylist(playlist);
    }));

    const hint = document.createElement('p');
    hint.className = 'playlist-open-hint';
    hint.textContent = 'Open the card or use the controls below to manage this mix.';

    card.appendChild(artWrap);
    card.appendChild(title);
    card.appendChild(description);
    card.appendChild(meta);
    card.appendChild(actions);
    card.appendChild(hint);
    return card;
  }

  function renderPlaylists(playlists) {
    const grid = document.getElementById('playlistGrid');
    const emptyState = document.getElementById('emptyState');
    const filterEmptyState = document.getElementById('filterEmptyState');
    const controls = document.getElementById('libraryControls');
    const infoBox = document.getElementById('infoBox');
    const lastCreatedPlaylistId = sessionStorage.getItem('lastCreatedPlaylistId');

    grid.innerHTML = '';

    if (!allPlaylists.length) {
      emptyState.classList.add('visible');
      filterEmptyState.classList.remove('visible');
      controls.style.display = 'none';
      grid.style.display = 'none';
      infoBox.style.display = 'none';
      return;
    }

    emptyState.classList.remove('visible');
    controls.style.display = 'grid';
    infoBox.style.display = 'flex';

    if (!playlists.length) {
      filterEmptyState.classList.add('visible');
      grid.style.display = 'none';
      return;
    }

    filterEmptyState.classList.remove('visible');
    grid.style.display = 'grid';
    infoBox.style.display = 'flex';

    playlists.forEach(function(playlist) {
      grid.appendChild(createPlaylistCard(playlist, lastCreatedPlaylistId));
    });
  }

  function applyFilters() {
    const visiblePlaylists = getVisiblePlaylists();
    updateResultsNote(visiblePlaylists.length, allPlaylists.length);
    renderPlaylists(visiblePlaylists);
  }

  function openRenameModal(playlist) {
    renameTargetId = playlist.id;
    renameTargetTitle.textContent = playlist.name;
    renameInput.value = playlist.name;
    renameSubmitBtn.textContent = 'Save Name';
    renameSubmitBtn.disabled = false;
    renameModal.classList.add('visible');
    renameInput.focus();
    renameInput.select();
  }

  function closeRenameModal() {
    renameTargetId = null;
    renameModal.classList.remove('visible');
    renameForm.reset();
  }

  async function sharePlaylist(playlist) {
    if (!playlist.externalUrl) {
      showLibraryMessage('This playlist does not have a shareable Spotify link yet.', 'error');
      return;
    }

    if (navigator.share) {
      try {
        await navigator.share({
          title: playlist.name,
          text: 'Shared from Daily Dev Mix',
          url: playlist.externalUrl,
        });
        showLibraryMessage('Share sheet opened for ' + playlist.name + '.', 'success');
        return;
      } catch (error) {
        if (error && error.name === 'AbortError') {
          return;
        }
      }
    }

    try {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        await navigator.clipboard.writeText(playlist.externalUrl);
        showLibraryMessage('Copied the playlist link for ' + playlist.name + '.', 'success');
        return;
      }
    } catch (error) {
      // Fall through to the manual copy prompt when clipboard access is blocked.
    }

    window.prompt('Copy this playlist link', playlist.externalUrl);
    showLibraryMessage('Use the dialog to copy the playlist link.', 'info');
  }

  async function removePlaylist(playlist) {
    const shouldRemove = window.confirm(
      'Remove "' + playlist.name + '" from your Spotify library?'
    );

    if (!shouldRemove) {
      return;
    }

    try {
      const response = await fetch('/api/playlists/' + encodeURIComponent(playlist.id), {
        method: 'DELETE',
      });

      if (response.status === 401) {
        window.location.href = '/login';
        return;
      }

      const payload = await response.json();

      if (!response.ok) {
        throw new Error(payload.message || 'The playlist could not be removed.');
      }

      allPlaylists = allPlaylists.filter(function(entry) {
        return entry.id !== playlist.id;
      });

      if (sessionStorage.getItem('lastCreatedPlaylistId') === playlist.id) {
        sessionStorage.removeItem('lastCreatedPlaylistId');
      }

      applyFilters();
      showLibraryMessage(payload.message || 'Playlist removed from your library.', 'success');
    } catch (error) {
      showLibraryMessage(error.message, 'error');
    }
  }

  function checkForNewPlaylist() {
    const isNew = sessionStorage.getItem('newPlaylist');
    if (isNew) {
      const banner = document.getElementById('successBanner');
      banner.classList.add('visible');
      sessionStorage.removeItem('newPlaylist');

      // Auto-hide the banner after 5 seconds
      setTimeout(function() {
        banner.classList.remove('visible');
      }, 5000);
    }
  }

  async function loadPlaylists() {
    const response = await fetch('/api/playlists');

    if (response.status === 401) {
      window.location.href = '/login';
      return;
    }

    const payload = await response.json();

    if (!response.ok) {
      throw new Error(payload.message || 'Spotify playlists could not be loaded.');
    }

    allPlaylists = payload.playlists || [];
    applyFilters();

    if (payload.warning) {
      showLibraryMessage(payload.warning, 'info');
    } else {
      showLibraryMessage('', '');
    }
  }

  renameForm.addEventListener('submit', async function(event) {
    event.preventDefault();

    if (!renameTargetId) {
      return;
    }

    renameSubmitBtn.disabled = true;
    renameSubmitBtn.textContent = 'Saving...';

    try {
      const response = await fetch('/api/playlists/' + encodeURIComponent(renameTargetId), {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          name: renameInput.value.trim(),
        }),
      });

      if (response.status === 401) {
        window.location.href = '/login';
        return;
      }

      const payload = await response.json();

      if (!response.ok) {
        throw new Error(payload.message || 'The playlist name could not be updated.');
      }

      allPlaylists = allPlaylists.map(function(playlist) {
        if (playlist.id !== renameTargetId) {
          return playlist;
        }

        return {
          ...playlist,
          ...payload.playlist,
        };
      });

      closeRenameModal();
      applyFilters();
      showLibraryMessage('Renamed playlist to "' + payload.playlist.name + '".', 'success');
    } catch (error) {
      renameSubmitBtn.disabled = false;
      renameSubmitBtn.textContent = 'Save Name';
      showLibraryMessage(error.message, 'error');
    }
  });

  renameCancelBtn.addEventListener('click', closeRenameModal);

  renameModal.addEventListener('click', function(event) {
    if (event.target === renameModal) {
      closeRenameModal();
    }
  });

  document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape' && renameModal.classList.contains('visible')) {
      closeRenameModal();
    }
  });

  searchInput.addEventListener('input', applyFilters);
  sortSelect.addEventListener('change', applyFilters);

  checkForNewPlaylist();
  loadPlaylists().catch(function(error) {
    document.getElementById('emptyState').classList.add('visible');
    document.getElementById('playlistGrid').style.display = 'none';
    document.getElementById('libraryControls').style.display = 'none';
    document.getElementById('filterEmptyState').classList.remove('visible');
    document.getElementById('infoBox').style.display = 'none';
    document.querySelector('.empty-desc').textContent = error.message;
  });
</script>
